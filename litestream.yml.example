# Copy to litestream.yml and edit. The real file is gitignored.
# Enable the `litestream` service in docker-compose.yml and set
# S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY in .env.
#
# Works with any S3-compatible store (AWS S3, Cloudflare R2, MinIO, Backblaze B2).

dbs:
  - path: /data/wakapi.db
    replicas:
      - type: s3
        bucket: YOUR_BUCKET
        path: wakapi
        # For Cloudflare R2:
        #   endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
        #   region:   auto
        # For AWS S3: set region, omit endpoint.
        endpoint: https://YOUR_ACCOUNT.r2.cloudflarestorage.com
        region: auto
