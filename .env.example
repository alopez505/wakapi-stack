# =============================================================================
#  Copy to .env and fill in your values.  `mise run init` does this automatically
#  and generates the WAKAPI_SALT for you.
#
#  .env is gitignored — it is what makes each machine behave differently.
#  The repo itself is identical everywhere.
# =============================================================================

# --- This machine's role -----------------------------------------------------
#   host    -> runs the Docker stack (Wakapi, tunnel, ...). Exactly ONE machine.
#   client  -> only writes ~/.wakatime.cfg to report to the host. All others.
#
# REQUIRED — no default. Leaving this blank will cause `mise run up` to fail
# with a clear error rather than silently starting Docker on a client machine.
ROLE=

# --- Required on the HOST ----------------------------------------------------

# Password hashing salt (mise run init fills this; or: openssl rand -base64 32)
WAKAPI_SALT=

# Public URL of the server (used by Wakapi itself and by client-setup.sh).
# For local-only use: http://localhost:3000
# For Cloudflare Tunnel: https://wakapi.example.com
WAKAPI_PUBLIC_URL=http://localhost:3000

# Which optional services run (comma-separated): empty | tunnel | autoupdate
# Leave empty for local-only mode. Add "tunnel" when CF_TUNNEL_TOKEN is ready.
COMPOSE_PROFILES=

# First run only: set true to create your account, then set false immediately.
# Leaving this true on a public hostname is a security risk.
WAKAPI_ALLOW_SIGNUP=false

# Keep false for public HTTPS. Set true only for local-only HTTP testing if
# login cookies do not persist.
WAKAPI_INSECURE_COOKIES=false

# Cloudflare Tunnel token (only when COMPOSE_PROFILES includes "tunnel").
# Get this from: Zero Trust Dashboard -> Networks -> Tunnels -> your tunnel -> Configure
CF_TUNNEL_TOKEN=

# --- Required on CLIENTS -----------------------------------------------------
# Your Wakapi API key (Settings page on the dashboard after signing in).
# Clients use this + WAKAPI_PUBLIC_URL above to write ~/.wakatime.cfg.
# Leave blank on the host machine.
WAKAPI_API_KEY=

# --- Optional: pin image versions --------------------------------------------
# WAKAPI_VERSION=2.17.4
# CLOUDFLARED_VERSION=2026.5.2
# WATCHTOWER_VERSION=1.7.1
# LITESTREAM_VERSION=v0.5.11

# --- Optional: change the local port -----------------------------------------
# WAKAPI_LOCAL_PORT=3000

# --- Optional: Postgres (see docker-compose.yml) -----------------------------
# WAKAPI_DB_TYPE=postgres
# WAKAPI_DB_HOST=wakapi-db
# WAKAPI_DB_PORT=5432
# WAKAPI_DB_USER=wakapi
# WAKAPI_DB_NAME=wakapi
# WAKAPI_DB_PASSWORD=

# --- Optional: Litestream -> S3/R2 backup ------------------------------------
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
